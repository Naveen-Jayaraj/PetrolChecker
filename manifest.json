{
  "name": "Petrol Tracker",
  "short_name": "Petrol Tracker",
  "description": "Calculate distance and track petrol refills for your vehicles.",
  "start_url": "./index.html",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#f9c123",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Quick Add Fuel",
      "short_name": "Refill",
      "description": "Log a new fuel refill",
      "url": "/?action=quick-add",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Update Odometer",
      "short_name": "Odometer",
      "description": "Quickly update current odometer reading",
      "url": "/?action=update-odo",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    }
  ],
  "widgets": [
    {
      "name": "KM Left Widget",
      "description": "See your remaining range",
      "tag": "widget-km-left",
      "template": "widget-km-left.html",
      "ms_ac_template": "widget-km-left.html",
      "data": "widget-data.json",
      "type": "application/json"
    },
    {
      "name": "Update Odometer Widget",
      "description": "Update odometer reading directly from widget",
      "tag": "widget-odo",
      "template": "widget-odo.html",
      "ms_ac_template": "widget-odo.html",
      "data": "widget-data.json",
      "type": "application/json"
    },
    {
      "name": "Quick Add Fuel Widget",
      "description": "Add fuel directly from widget",
      "tag": "widget-add-fuel",
      "template": "widget-add-fuel.html",
      "ms_ac_template": "widget-add-fuel.html",
      "data": "widget-data.json",
      "type": "application/json"
    },
    {
      "name": "Petrol Dashboard",
      "description": "Combined dashboard widget",
      "tag": "widget-dashboard",
      "template": "widget-dashboard.html",
      "ms_ac_template": "widget-dashboard.html",
      "data": "widget-data.json",
      "type": "application/json"
    }
  ]
}
